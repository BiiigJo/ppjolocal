src/App.tsx:              </TabsTrigger>
src/App.tsx:            </TabsList>
src/App.tsx:          </div>
src/App.tsx:        </Tabs>
src/App.tsx:      </main>
src/App.tsx:      <Toaster position="top-center" />
src/App.tsx:    </div>
src/App.tsx:  );
src/App.tsx:}
