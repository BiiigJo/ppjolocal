src/components/OutfitGenerator.tsx:      }
src/components/OutfitGenerator.tsx:    );
src/components/OutfitGenerator.tsx:    return () => unsubscribe();
src/components/OutfitGenerator.tsx:  }, [user]);
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:  const generate = async () => {
src/components/OutfitGenerator.tsx:    if (!occasion) {
src/components/OutfitGenerator.tsx:      toast.error("Veuillez préciser l'occasion");
src/components/OutfitGenerator.tsx:      return;
src/components/OutfitGenerator.tsx:    }
src/components/OutfitGenerator.tsx:    if (wardrobe.length < 3) {
src/components/OutfitGenerator.tsx:      toast.error("Ajoutez plus de vêtements à votre dressing pour obtenir des suggestions");
src/components/OutfitGenerator.tsx:      return;
src/components/OutfitGenerator.tsx:    }
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:    setLoading(true);
