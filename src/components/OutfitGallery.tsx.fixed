src/lib/demo-storage.ts:};
src/lib/demo-storage.ts:
src/lib/demo-storage.ts:export const demoStorage = {
src/lib/demo-storage.ts:  subscribe: (listener: () => void) => {
src/lib/demo-storage.ts:    listeners.push(listener);
src/lib/demo-storage.ts:    return () => {
src/lib/demo-storage.ts:      listeners = listeners.filter(l => l !== listener);
src/lib/demo-storage.ts:    };
src/lib/demo-storage.ts:  },
src/lib/demo-storage.ts:  getClothing: (): ClothingItem[] => {
src/lib/demo-storage.ts:    const data = localStorage.getItem(CLOTHING_KEY);
src/lib/demo-storage.ts:    return data ? JSON.parse(data) : [];
src/lib/demo-storage.ts:  },
src/lib/demo-storage.ts:  saveClothing: (item: ClothingItem) => {
src/lib/demo-storage.ts:    const items = demoStorage.getClothing();
src/lib/demo-storage.ts:    items.unshift(item);
src/lib/demo-storage.ts:    localStorage.setItem(CLOTHING_KEY, JSON.stringify(items));
src/lib/demo-storage.ts:    notify();
src/lib/demo-storage.ts:  },
src/lib/demo-storage.ts:  deleteClothing: (id: string) => {
src/lib/demo-storage.ts:    const items = demoStorage.getClothing().filter(i => i.id !== id);
src/lib/demo-storage.ts:    localStorage.setItem(CLOTHING_KEY, JSON.stringify(items));
src/lib/demo-storage.ts:    notify();
src/lib/demo-storage.ts:  },
src/lib/demo-storage.ts:  getOutfits: (): Outfit[] => {
src/lib/demo-storage.ts:    const data = localStorage.getItem(OUTFITS_KEY);
src/lib/demo-storage.ts:    return data ? JSON.parse(data) : [];
src/lib/demo-storage.ts:  },
src/lib/demo-storage.ts:  saveOutfit: (outfit: Outfit) => {
src/lib/demo-storage.ts:    const outfits = demoStorage.getOutfits();
src/lib/demo-storage.ts:    const hash = outfit.photoHash;
src/lib/demo-storage.ts:    // Simple duplicate check within same session if possible
src/lib/demo-storage.ts:    if (outfits.some(o => o.photoHash === hash)) return;
src/lib/demo-storage.ts:    
src/lib/demo-storage.ts:    outfits.unshift(outfit);
src/lib/demo-storage.ts:    localStorage.setItem(OUTFITS_KEY, JSON.stringify(outfits));
src/lib/demo-storage.ts:    notify();
src/lib/demo-storage.ts:  },
src/lib/demo-storage.ts:  deleteOutfit: (id: string) => {
src/lib/demo-storage.ts:    const outfits = demoStorage.getOutfits().filter(o => o.id !== id);
src/lib/demo-storage.ts:    localStorage.setItem(OUTFITS_KEY, JSON.stringify(outfits));
src/lib/demo-storage.ts:    notify();
src/lib/demo-storage.ts:  },
src/lib/demo-storage.ts:  updateOutfit: (id: string, updates: Partial<Outfit>) => {
src/lib/demo-storage.ts:    const outfits = demoStorage.getOutfits().map(o => o.id === id ? { ...o, ...updates } : o);
src/lib/demo-storage.ts:    localStorage.setItem(OUTFITS_KEY, JSON.stringify(outfits));
src/lib/demo-storage.ts:    notify();
src/lib/demo-storage.ts:  },
src/lib/demo-storage.ts:  updateClothing: (id: string, updates: Partial<ClothingItem>) => {
src/lib/demo-storage.ts:    const items = demoStorage.getClothing().map(i => i.id === id ? { ...i, ...updates } : i);
src/lib/demo-storage.ts:    localStorage.setItem(CLOTHING_KEY, JSON.stringify(items));
src/lib/demo-storage.ts:    notify();
src/lib/demo-storage.ts:  }
src/lib/demo-storage.ts:};
src/lib/image-utils.ts:
src/lib/image-utils.ts:/**
src/lib/image-utils.ts: * Compresses a base64 image string by resizing it and reducing quality.
src/lib/image-utils.ts: * This is crucial for staying within LocalStorage (5MB) and Firestore (1MB) limits.
src/lib/image-utils.ts: */
src/lib/image-utils.ts:export async function compressImage(base64Str: string, maxWidth = 1024, maxHeight = 1024, quality = 0.7): Promise<string> {
src/lib/image-utils.ts:  // If it's already a tiny string or empty, avoid processing
src/lib/image-utils.ts:  if (!base64Str || base64Str.length < 100) return base64Str;
src/lib/image-utils.ts:
src/lib/image-utils.ts:  return new Promise((resolve, reject) => {
src/lib/image-utils.ts:    const img = new Image();
src/lib/image-utils.ts:    img.crossOrigin = "anonymous";
src/lib/image-utils.ts:    img.src = base64Str;
src/lib/image-utils.ts:    img.onload = () => {
src/lib/image-utils.ts:      try {
src/lib/image-utils.ts:        const canvas = document.createElement("canvas");
src/lib/image-utils.ts:        let width = img.width;
src/lib/image-utils.ts:        let height = img.height;
src/lib/image-utils.ts:
src/lib/image-utils.ts:        // Calculate new dimensions maintain aspect ratio
src/lib/image-utils.ts:        if (width > height) {
src/lib/image-utils.ts:          if (width > maxWidth) {
src/lib/image-utils.ts:            height *= maxWidth / width;
src/lib/image-utils.ts:            width = maxWidth;
src/lib/image-utils.ts:          }
src/lib/image-utils.ts:        } else {
src/lib/image-utils.ts:          if (height > maxHeight) {
src/lib/image-utils.ts:            width *= maxHeight / height;
src/lib/image-utils.ts:            height = maxHeight;
src/lib/image-utils.ts:          }
src/lib/image-utils.ts:        }
src/lib/image-utils.ts:
src/lib/image-utils.ts:        canvas.width = width;
src/lib/image-utils.ts:        canvas.height = height;
src/lib/image-utils.ts:
src/lib/image-utils.ts:        const ctx = canvas.getContext("2d");
src/lib/image-utils.ts:        if (!ctx) {
src/lib/image-utils.ts:          throw new Error("Could not get canvas context");
src/lib/image-utils.ts:        }
src/lib/image-utils.ts:
src/lib/image-utils.ts:        ctx.drawImage(img, 0, 0, width, height);
src/lib/image-utils.ts:        
src/lib/image-utils.ts:        // Output as compressed JPEG
src/lib/image-utils.ts:        const result = canvas.toDataURL("image/jpeg", quality);
src/lib/image-utils.ts:        resolve(result);
src/lib/image-utils.ts:      } catch (err) {
src/lib/image-utils.ts:        console.error("Compression error in onload:", err);
src/lib/image-utils.ts:        reject(err);
src/lib/image-utils.ts:      }
src/lib/image-utils.ts:    };
src/lib/image-utils.ts:    img.onerror = (err) => {
src/lib/image-utils.ts:      console.error("Image loading error for compression:", err);
src/lib/image-utils.ts:      reject(new Error("Image loading failed"));
src/lib/image-utils.ts:    };
src/lib/image-utils.ts:  });
src/lib/image-utils.ts:}
src/lib/image-utils.ts:
src/lib/image-utils.ts:/**
src/lib/image-utils.ts: * Generates a simple hash for a string (like base64 image) to help with deduplication.
src/lib/image-utils.ts: */
src/lib/image-utils.ts:export function generateHash(str: string): string {
src/lib/image-utils.ts:  let hash = 0;
src/lib/image-utils.ts:  for (let i = 0; i < str.length; i++) {
src/lib/image-utils.ts:    const char = str.charCodeAt(i);
src/lib/image-utils.ts:    hash = ((hash << 5) - hash) + char;
src/lib/image-utils.ts:    hash = hash & hash; // Convert to 32bit integer
src/lib/image-utils.ts:  }
src/lib/image-utils.ts:  return hash.toString(36);
src/lib/image-utils.ts:}
src/lib/error-handler.ts:import { auth } from "@/lib/firebase";
src/lib/error-handler.ts:import { OperationType, FirestoreErrorInfo } from "@/types";
src/lib/error-handler.ts:
src/lib/error-handler.ts:export function handleFirestoreError(error: unknown, operationType: OperationType, path: string | null) {
src/lib/error-handler.ts:  const errInfo: FirestoreErrorInfo = {
src/lib/error-handler.ts:    error: error instanceof Error ? error.message : String(error),
src/lib/error-handler.ts:    authInfo: {
src/lib/error-handler.ts:      userId: auth.currentUser?.uid,
src/lib/error-handler.ts:      email: auth.currentUser?.email || undefined,
src/lib/error-handler.ts:      emailVerified: auth.currentUser?.emailVerified || undefined,
src/lib/error-handler.ts:      isAnonymous: auth.currentUser?.isAnonymous || undefined,
src/lib/error-handler.ts:      tenantId: auth.currentUser?.tenantId,
src/lib/error-handler.ts:      providerInfo: auth.currentUser?.providerData.map(provider => ({
src/lib/error-handler.ts:        providerId: provider.providerId,
src/lib/error-handler.ts:        displayName: provider.displayName,
src/lib/error-handler.ts:        email: provider.email,
src/lib/error-handler.ts:        photoUrl: provider.photoURL
src/lib/error-handler.ts:      })) || []
src/lib/error-handler.ts:    },
src/lib/error-handler.ts:    operationType,
src/lib/error-handler.ts:    path
src/lib/error-handler.ts:  };
src/lib/error-handler.ts:  console.error('Firestore Error: ', JSON.stringify(errInfo));
src/lib/error-handler.ts:  throw new Error(JSON.stringify(errInfo));
src/lib/error-handler.ts:}
src/lib/weather.ts:export interface WeatherData {
src/lib/weather.ts:  temp: number;
