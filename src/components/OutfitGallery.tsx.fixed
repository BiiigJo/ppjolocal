src/components/OutfitGenerator.tsx:    }
src/components/OutfitGenerator.tsx:  };
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:  const saveOutfit = async (suggestion: any) => {
src/components/OutfitGenerator.tsx:    if (!user) return;
src/components/OutfitGenerator.tsx:    
src/components/OutfitGenerator.tsx:    const isDemo = user.uid === "demo-user";
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:    // Match suggestion items with wardrobe IDs
src/components/OutfitGenerator.tsx:    const itemIds = suggestion.items.map((itemName: string) => {
