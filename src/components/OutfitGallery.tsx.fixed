src/components/Scanner.tsx:const cropImageFromBox = (base64Str: string, box_2d: number[]): Promise<string> => {
src/components/Scanner.tsx:  return new Promise((resolve, reject) => {
src/components/Scanner.tsx:    const img = new Image();
src/components/Scanner.tsx:    img.crossOrigin = "anonymous";
src/components/Scanner.tsx:    img.onload = () => {
src/components/Scanner.tsx:      const canvas = document.createElement('canvas');
src/components/Scanner.tsx:      const ctx = canvas.getContext('2d');
src/components/Scanner.tsx:      if (!ctx) {
src/components/Scanner.tsx:        reject(new Error("Failed to get canvas context"));
src/components/Scanner.tsx:        return;
src/components/Scanner.tsx:      }
src/components/Scanner.tsx:
src/components/Scanner.tsx:      const [ymin, xmin, ymax, xmax] = box_2d;
src/components/Scanner.tsx:      const x = (xmin / 1000) * img.width;
src/components/Scanner.tsx:      const y = (ymin / 1000) * img.height;
src/components/Scanner.tsx:      const width = ((xmax - xmin) / 1000) * img.width;
src/components/Scanner.tsx:      const height = ((ymax - ymin) / 1000) * img.height;
src/components/Scanner.tsx:
src/components/Scanner.tsx:      const paddingX = width * 0.15;
src/components/Scanner.tsx:      const paddingY = height * 0.15;
src/components/Scanner.tsx:      
src/components/Scanner.tsx:      const targetX = Math.max(0, x - paddingX);
src/components/Scanner.tsx:      const targetY = Math.max(0, y - paddingY);
src/components/Scanner.tsx:      const targetWidth = Math.min(img.width - targetX, width + paddingX * 2);
src/components/Scanner.tsx:      const targetHeight = Math.min(img.height - targetY, height + paddingY * 2);
src/components/Scanner.tsx:
src/components/Scanner.tsx:      canvas.width = targetWidth;
src/components/Scanner.tsx:      canvas.height = targetHeight;
src/components/Scanner.tsx:      ctx.drawImage(img, targetX, targetY, targetWidth, targetHeight, 0, 0, targetWidth, targetHeight);
src/components/Scanner.tsx:      
src/components/Scanner.tsx:      resolve(canvas.toDataURL('image/jpeg', 0.8));
src/components/Scanner.tsx:    };
src/components/Scanner.tsx:    img.onerror = () => reject(new Error("Failed to load image for cropping"));
src/components/Scanner.tsx:    img.src = base64Str;
src/components/Scanner.tsx:  });
src/components/Scanner.tsx:};
