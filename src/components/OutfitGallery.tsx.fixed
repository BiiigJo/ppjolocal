src/App.tsx:                  <ImageIcon className="w-5 h-5" />
src/App.tsx:                  <span className="text-[10px] font-bold">Outfits</span>
src/App.tsx:                </div>
src/App.tsx:              </TabsTrigger>
src/App.tsx:              <TabsTrigger 
src/App.tsx:                value="generator" 
src/App.tsx:                className="rounded-xl data-[state=active]:bg-zinc-900 data-[state=active]:text-white data-[state=active]:shadow-lg transition-all duration-300"
src/App.tsx:              >
src/App.tsx:                <div className="flex flex-col items-center gap-1">
src/App.tsx:                  <Sparkles className="w-5 h-5" />
src/App.tsx:                  <span className="text-[10px] font-bold">IA</span>
