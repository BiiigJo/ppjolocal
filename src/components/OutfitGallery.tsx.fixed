firestore.rules:rules_version = '2';
firestore.rules:
firestore.rules:service cloud.firestore {
firestore.rules:  match /databases/{database}/documents {
firestore.rules:    
firestore.rules:    // Helper functions
firestore.rules:    function isAuthenticated() {
firestore.rules:      return request.auth != null;
firestore.rules:    }
firestore.rules:    
firestore.rules:    function isOwner(userId) {
firestore.rules:      return isAuthenticated() && request.auth.uid == userId;
firestore.rules:    }
firestore.rules:    
firestore.rules:    function isDocOwner() {
firestore.rules:      return isAuthenticated() && request.auth.uid == resource.data.userId;
firestore.rules:    }
firestore.rules:    
firestore.rules:    function isValidClothingItem(data) {
firestore.rules:      return data.keys().hasAll(['name', 'category', 'type', 'color', 'style', 'imageUrl', 'userId', 'createdAt']) &&
firestore.rules:             data.name is string && data.name.size() < 100 &&
firestore.rules:             data.category is string && data.category.size() < 50 &&
firestore.rules:             data.type is string && data.type.size() < 50 &&
firestore.rules:             data.color is string && data.color.size() < 50 &&
firestore.rules:             data.style is string && data.style.size() < 50 &&
firestore.rules:             data.imageUrl is string && data.imageUrl.size() < 1500000 && // 1.5MB max for base64
firestore.rules:             data.userId == request.auth.uid &&
firestore.rules:             data.createdAt is string &&
firestore.rules:             (!('brand' in data) || (data.brand is string && data.brand.size() < 100)) &&
firestore.rules:             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
firestore.rules:             (!('careInstructions' in data) || (data.careInstructions is string && data.careInstructions.size() < 1000)) &&
firestore.rules:             (!('season' in data) || (data.season is string && data.season.size() < 50));
firestore.rules:    }
firestore.rules:    
firestore.rules:    function isValidOutfit(data) {
firestore.rules:      let requiredFields = ['name', 'itemIds', 'date', 'photoUrl', 'photoHash', 'hashtags', 'dominantColor', 'occasion', 'userId', 'createdAt'];
firestore.rules:      return data.keys().hasAll(requiredFields) &&
firestore.rules:             data.name is string && data.name.size() < 200 &&
firestore.rules:             data.itemIds is list &&
firestore.rules:             data.date is string &&
firestore.rules:             data.photoUrl is string && data.photoUrl.size() < 1500000 &&
firestore.rules:             data.photoHash is string && data.photoHash.size() < 64 &&
firestore.rules:             data.hashtags is list &&
firestore.rules:             data.dominantColor is string &&
firestore.rules:             data.occasion is string &&
firestore.rules:             data.userId == request.auth.uid &&
firestore.rules:             data.createdAt is string;
firestore.rules:    }
firestore.rules:
firestore.rules:    match /clothingItems/{itemId} {
firestore.rules:      allow read: if isDocOwner();
firestore.rules:      allow create: if isAuthenticated() && isValidClothingItem(request.resource.data);
firestore.rules:      allow update: if isDocOwner() && isValidClothingItem(request.resource.data) && request.resource.data.userId == resource.data.userId;
firestore.rules:      allow delete: if isDocOwner();
firestore.rules:    }
firestore.rules:
firestore.rules:    match /outfits/{outfitId} {
firestore.rules:      allow read: if isDocOwner();
firestore.rules:      allow create: if isAuthenticated() && isValidOutfit(request.resource.data);
firestore.rules:      allow update: if isDocOwner() && isValidOutfit(request.resource.data) && request.resource.data.userId == resource.data.userId;
firestore.rules:      allow delete: if isDocOwner();
firestore.rules:    }
firestore.rules:    
firestore.rules:    match /users/{userId} {
firestore.rules:      allow read, write: if isOwner(userId);
firestore.rules:    }
firestore.rules:  }
firestore.rules:}
vite.config.ts:import tailwindcss from '@tailwindcss/vite';
vite.config.ts:import react from '@vitejs/plugin-react';
vite.config.ts:import path from 'path';
vite.config.ts:import {defineConfig, loadEnv} from 'vite';
vite.config.ts:
vite.config.ts:export default defineConfig(({mode}) => {
vite.config.ts:  const env = loadEnv(mode, '.', '');
vite.config.ts:  return {
vite.config.ts:    plugins: [react(), tailwindcss()],
vite.config.ts:    define: {
vite.config.ts:      'process.env.GEMINI_API_KEY': JSON.stringify(env.GEMINI_API_KEY),
vite.config.ts:    },
vite.config.ts:    resolve: {
vite.config.ts:      alias: {
vite.config.ts:        '@': path.resolve(__dirname, './src'),
vite.config.ts:      },
vite.config.ts:    },
vite.config.ts:    server: {
vite.config.ts:      // HMR is disabled in AI Studio via DISABLE_HMR env var.
vite.config.ts:      // Do not modifyâfile watching is disabled to prevent flickering during agent edits.
vite.config.ts:      hmr: process.env.DISABLE_HMR !== 'true',
vite.config.ts:    },
vite.config.ts:  };
vite.config.ts:});
