src/components/OutfitGenerator.tsx:  const [selectedDate, setSelectedDate] = useState<Date>(new Date());
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:  useEffect(() => {
src/components/OutfitGenerator.tsx:    if (!user) return;
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:    const isDemo = user.uid === "demo-user";
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:    if (isDemo) {
src/components/OutfitGenerator.tsx:      setWardrobe(demoStorage.getClothing());
