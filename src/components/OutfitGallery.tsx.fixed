metadata.json:  "description": "Scanner de vêtements et gestionnaire d'outfits intelligent avec IA. Scannez vos vêtements, organisez votre garde-robe et générez des tenues pour chaque occasion.",
metadata.json:  "requestFramePermissions": ["camera", "geolocation"],
metadata.json:  "majorCapabilities": []
metadata.json:}
