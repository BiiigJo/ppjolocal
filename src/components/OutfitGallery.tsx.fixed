src/components/OutfitGenerator.tsx:      };
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:      if (isDemo) {
src/components/OutfitGenerator.tsx:        demoStorage.saveOutfit({ ...newOutfit, id: Math.random().toString(36).substr(2, 9) });
src/components/OutfitGenerator.tsx:        toast.success("Tenue enregistrée (Mode Démo) !");
src/components/OutfitGenerator.tsx:      } else {
src/components/OutfitGenerator.tsx:        const path = "outfits";
src/components/OutfitGenerator.tsx:        await addDoc(collection(db, path), newOutfit);
src/components/OutfitGenerator.tsx:        toast.success("Tenue enregistrée dans votre galerie !");
src/components/OutfitGenerator.tsx:      }
src/components/OutfitGenerator.tsx:    } catch (err) {
src/components/OutfitGenerator.tsx:      handleFirestoreError(err, OperationType.CREATE, "outfits");
src/components/OutfitGenerator.tsx:    }
src/components/OutfitGenerator.tsx:  };
src/components/OutfitGenerator.tsx:
