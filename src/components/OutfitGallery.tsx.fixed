index.html:<!doctype html>
index.html:<html lang="en">
index.html:  <head>
index.html:    <meta charset="UTF-8" />
index.html:    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
index.html:    <title>My Google AI Studio App</title>
index.html:  </head>
index.html:  <body>
index.html:    <div id="root"></div>
index.html:    <script type="module" src="/src/main.tsx"></script>
index.html:  </body>
index.html:</html>
index.html:
.env.example:# GEMINI_API_KEY: Required for Gemini AI API calls.
.env.example:# AI Studio automatically injects this at runtime from user secrets.
.env.example:# Users configure this via the Secrets panel in the AI Studio UI.
.env.example:GEMINI_API_KEY="MY_GEMINI_API_KEY"
.env.example:
.env.example:# APP_URL: The URL where this applet is hosted.
.env.example:# AI Studio automatically injects this at runtime with the Cloud Run service URL.
.env.example:# Used for self-referential links, OAuth callbacks, and API endpoints.
.env.example:APP_URL="MY_APP_URL"
