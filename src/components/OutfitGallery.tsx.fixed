src/lib/weather.ts:
src/lib/weather.ts:export async function fetchWeather(lat: number, lon: number): Promise<WeatherData> {
src/lib/weather.ts:  const [weatherRes, geoRes] = await Promise.all([
src/lib/weather.ts:    fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`),
src/lib/weather.ts:    fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json`)
src/lib/weather.ts:  ]);
src/lib/weather.ts:
src/lib/weather.ts:  const data = await weatherRes.json();
src/lib/weather.ts:  const geoData = await geoRes.json();
src/lib/weather.ts:  
src/lib/weather.ts:  const temp = Math.round(data.current_weather.temperature);
src/lib/weather.ts:  const code = data.current_weather.weathercode;
src/lib/weather.ts:  const city = geoData.address.city || geoData.address.town || geoData.address.village || geoData.address.municipality || "Ma Position";
src/lib/weather.ts:  
src/lib/weather.ts:  // Map WMO Weather interpretation codes to simple descriptions and icons
src/lib/weather.ts:  // https://open-meteo.com/en/docs
src/lib/weather.ts:  const weatherMap: Record<number, { condition: string; icon: string }> = {
src/lib/weather.ts:    0: { condition: "Ciel dégagé", icon: "☀️" },
src/lib/weather.ts:    1: { condition: "Principalement dégagé", icon: "🌤️" },
src/lib/weather.ts:    2: { condition: "Partiellement nuageux", icon: "⛅" },
src/lib/weather.ts:    3: { condition: "Couvert", icon: "☁️" },
src/lib/weather.ts:    45: { condition: "Brouillard", icon: "🌫️" },
src/lib/weather.ts:    48: { condition: "Brouillard givrant", icon: "🌫️" },
src/lib/weather.ts:    51: { condition: "Bruine légère", icon: "🌧️" },
src/lib/weather.ts:    53: { condition: "Bruine modérée", icon: "🌧️" },
src/lib/weather.ts:    55: { condition: "Bruine dense", icon: "🌧️" },
src/lib/weather.ts:    61: { condition: "Pluie légère", icon: "🌧️" },
src/lib/weather.ts:    63: { condition: "Pluie modérée", icon: "🌧️" },
src/lib/weather.ts:    65: { condition: "Pluie forte", icon: "🌧️" },
src/lib/weather.ts:    71: { condition: "Neige légère", icon: "❄️" },
src/lib/weather.ts:    73: { condition: "Neige modérée", icon: "❄️" },
src/lib/weather.ts:    75: { condition: "Neige forte", icon: "❄️" },
src/lib/weather.ts:    95: { condition: "Orage", icon: "⛈️" },
src/lib/weather.ts:  };
src/lib/weather.ts:
src/lib/weather.ts:  const { condition, icon } = weatherMap[code] || { condition: "Inconnu", icon: "🌡️" };
src/lib/weather.ts:
src/lib/weather.ts:  return { temp, condition, icon };
src/lib/weather.ts:}
