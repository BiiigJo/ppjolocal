firebase-blueprint.json:{
firebase-blueprint.json:  "entities": {
firebase-blueprint.json:    "ClothingItem": {
firebase-blueprint.json:      "title": "ClothingItem",
firebase-blueprint.json:      "description": "Un vêtement individuel scanné par l'utilisateur.",
firebase-blueprint.json:      "type": "object",
firebase-blueprint.json:      "properties": {
firebase-blueprint.json:        "name": { "type": "string", "description": "Nom ou description courte du vêtement" },
firebase-blueprint.json:        "category": { "type": "string", "description": "Catégorie (Haut, Bas, Chaussures, etc.)" },
firebase-blueprint.json:        "type": { "type": "string", "description": "Type spécifique (T-shirt, Jean, Baskets, etc.)" },
firebase-blueprint.json:        "color": { "type": "string", "description": "Couleur dominante" },
firebase-blueprint.json:        "style": { "type": "string", "description": "Style (Casual, Formel, Sport, etc.)" },
firebase-blueprint.json:        "season": { "type": "string", "description": "Saison (Printemps, Été, Automne, Hiver, Toutes saisons)" },
firebase-blueprint.json:        "imageUrl": { "type": "string", "description": "URL de l'image du vêtement" },
firebase-blueprint.json:        "userId": { "type": "string", "description": "ID de l'utilisateur propriétaire" },
firebase-blueprint.json:        "createdAt": { "type": "string", "format": "date-time", "description": "Date de création" }
firebase-blueprint.json:      },
firebase-blueprint.json:      "required": ["name", "category", "imageUrl", "userId", "createdAt"]
firebase-blueprint.json:    },
firebase-blueprint.json:    "Outfit": {
firebase-blueprint.json:      "title": "Outfit",
firebase-blueprint.json:      "description": "Une combinaison de vêtements (tenue) pour une date ou un événement.",
firebase-blueprint.json:      "type": "object",
firebase-blueprint.json:      "properties": {
firebase-blueprint.json:        "name": { "type": "string", "description": "Nom de la tenue" },
firebase-blueprint.json:        "itemIds": { "type": "array", "items": { "type": "string" }, "description": "Liste des IDs des vêtements composant la tenue" },
firebase-blueprint.json:        "date": { "type": "string", "format": "date", "description": "Date à laquelle la tenue a été portée" },
firebase-blueprint.json:        "photoUrl": { "type": "string", "description": "Photo optionnelle de la tenue complète" },
firebase-blueprint.json:        "occasion": { "type": "string", "description": "Occasion ou événement" },
firebase-blueprint.json:        "userId": { "type": "string", "description": "ID de l'utilisateur propriétaire" },
firebase-blueprint.json:        "createdAt": { "type": "string", "format": "date-time", "description": "Date de création" }
firebase-blueprint.json:      },
firebase-blueprint.json:      "required": ["itemIds", "date", "userId", "createdAt"]
firebase-blueprint.json:    }
firebase-blueprint.json:  },
firebase-blueprint.json:  "firestore": {
firebase-blueprint.json:    "/clothingItems/{itemId}": {
firebase-blueprint.json:      "schema": "ClothingItem",
firebase-blueprint.json:      "description": "Collection des vêtements individuels"
firebase-blueprint.json:    },
firebase-blueprint.json:    "/outfits/{outfitId}": {
firebase-blueprint.json:      "schema": "Outfit",
firebase-blueprint.json:      "description": "Collection des tenues enregistrées"
firebase-blueprint.json:    }
firebase-blueprint.json:  }
firebase-blueprint.json:}
