src/lib/gemini.ts:    },
src/lib/gemini.ts:    items: {
src/lib/gemini.ts:      type: Type.ARRAY,
src/lib/gemini.ts:      items: {
src/lib/gemini.ts:        type: Type.OBJECT,
src/lib/gemini.ts:        properties: {
src/lib/gemini.ts:          name: { type: Type.STRING, description: "Nom descriptif court du vêtement" },
src/lib/gemini.ts:          category: { type: Type.STRING, description: "Catégorie (Haut, Bas, Chaussures, Accessoire)" },
src/lib/gemini.ts:          type: { type: Type.STRING, description: "Type spécifique (T-shirt, Jean, Baskets, Veste, etc.)" },
src/lib/gemini.ts:          color: { type: Type.STRING, description: "Couleur dominante" },
src/lib/gemini.ts:          style: { type: Type.STRING, description: "Style (Casual, Formel, Sport, Chic, etc.)" },
src/lib/gemini.ts:          season: { type: Type.STRING, description: "Saison (Printemps, Été, Automne, Hiver, Toutes saisons)" },
src/lib/gemini.ts:          brand: { type: Type.STRING, description: "Marque du vêtement si visible ou reconnaissable, sinon laisser vide" },
src/lib/gemini.ts:          description: { type: Type.STRING, description: "Une brève description du vêtement" },
src/lib/gemini.ts:          careInstructions: { type: Type.STRING, description: "Conseils d'entretien (lavage, séchage, etc.) basés sur le type de tissu probable" },
src/lib/gemini.ts:          box_2d: { 
src/lib/gemini.ts:            type: Type.ARRAY, 
src/lib/gemini.ts:            items: { type: Type.NUMBER },
src/lib/gemini.ts:            description: "Coordonnées de la boîte englobante [ymin, xmin, ymax, xmax] normalisées à 1000 pour localiser l'objet dans l'image."
src/lib/gemini.ts:          },
src/lib/gemini.ts:        },
src/lib/gemini.ts:        required: ["name", "category", "type", "color", "style", "season", "brand", "description", "careInstructions", "box_2d"],
src/lib/gemini.ts:      }
src/lib/gemini.ts:    }
src/lib/gemini.ts:  },
src/lib/gemini.ts:  required: ["items", "poeticSuggestedTitle"],
src/lib/gemini.ts:};
src/lib/gemini.ts:
src/lib/gemini.ts:export async function recognizeClothing(base64Image: string, allowedColors: string[]) {
src/lib/gemini.ts:  const response = await ai.models.generateContent({
src/lib/gemini.ts:    model: "gemini-3-flash-preview",
src/lib/gemini.ts:    contents: [
src/lib/gemini.ts:      {
src/lib/gemini.ts:        parts: [
src/lib/gemini.ts:          {
src/lib/gemini.ts:            inlineData: {
src/lib/gemini.ts:              mimeType: "image/jpeg",
src/lib/gemini.ts:              data: base64Image.split(',')[1] || base64Image,
src/lib/gemini.ts:            },
src/lib/gemini.ts:          },
src/lib/gemini.ts:          {
src/lib/gemini.ts:            text: `Analyse cette image. S'il y a plusieurs vêtements, identifie-les tous séparément. 
src/lib/gemini.ts:            Détecte précisément la boîte englobante [ymin, xmin, ymax, xmax] pour chaque vêtement identifié.
src/lib/gemini.ts:            Calcule aussi un titre poétique et évocateur pour le look global.
src/lib/gemini.ts:            IMPORTANT pour la couleur: Choisis UNIQUEMENT la couleur dominante parmi cette liste: ${allowedColors.join(", ")}. 
src/lib/gemini.ts:            Si le vêtement a plusieurs couleurs, choisis la plus présente dans la liste. 
src/lib/gemini.ts:            Ne retourne AUCUNE autre couleur que celles de la liste.
src/lib/gemini.ts:            Retourne les détails au format JSON.`,
src/lib/gemini.ts:          },
src/lib/gemini.ts:        ],
src/lib/gemini.ts:      },
src/lib/gemini.ts:    ],
src/lib/gemini.ts:    config: {
src/lib/gemini.ts:      responseMimeType: "application/json",
src/lib/gemini.ts:      responseSchema: clothingRecognitionSchema,
src/lib/gemini.ts:    },
src/lib/gemini.ts:  });
src/lib/gemini.ts:
src/lib/gemini.ts:  const data = JSON.parse(response.text);
src/lib/gemini.ts:  return data;
src/lib/gemini.ts:}
