src/components/OutfitGenerator.tsx:                                       itemName.toLowerCase().includes(w.name.toLowerCase()));
src/components/OutfitGenerator.tsx:      return match?.id;
src/components/OutfitGenerator.tsx:    }).filter(Boolean);
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:    if (itemIds.length === 0) {
src/components/OutfitGenerator.tsx:      toast.error("Impossible de faire correspondre les vêtements suggérés avec votre dressing");
src/components/OutfitGenerator.tsx:      return;
src/components/OutfitGenerator.tsx:    }
src/components/OutfitGenerator.tsx:
src/components/OutfitGenerator.tsx:    try {
