src/lib/gemini.ts:export async function suggestOutfits(wardrobe: any[], occasion: string) {
src/lib/gemini.ts:  const wardrobeContext = wardrobe.map(item => `- ${item.name} (${item.type}, ${item.color}, ${item.style})`).join('\n');
src/lib/gemini.ts:  
src/lib/gemini.ts:  const response = await ai.models.generateContent({
src/lib/gemini.ts:    model: "gemini-3-flash-preview",
src/lib/gemini.ts:    contents: `Voici ma garde-robe :\n${wardrobeContext}\n\nSuggère-moi 3 tenues adaptées pour l'occasion suivante : ${occasion}. Pour chaque tenue, donne un nom, la liste des vêtements à utiliser et une brève explication du style. Réponds en français au format JSON.`,
src/lib/gemini.ts:    config: {
src/lib/gemini.ts:      responseMimeType: "application/json",
src/lib/gemini.ts:      responseSchema: {
src/lib/gemini.ts:        type: Type.ARRAY,
src/lib/gemini.ts:        items: {
src/lib/gemini.ts:          type: Type.OBJECT,
src/lib/gemini.ts:          properties: {
src/lib/gemini.ts:            name: { type: Type.STRING },
src/lib/gemini.ts:            items: { type: Type.ARRAY, items: { type: Type.STRING } },
src/lib/gemini.ts:            explanation: { type: Type.STRING },
src/lib/gemini.ts:          },
src/lib/gemini.ts:          required: ["name", "items", "explanation"],
src/lib/gemini.ts:        },
src/lib/gemini.ts:      },
src/lib/gemini.ts:    },
src/lib/gemini.ts:  });
src/lib/gemini.ts:
src/lib/gemini.ts:  return JSON.parse(response.text);
src/lib/gemini.ts:}
src/lib/demo-storage.ts:import { ClothingItem, Outfit } from "@/types";
src/lib/demo-storage.ts:
src/lib/demo-storage.ts:const CLOTHING_KEY = "stylescan_demo_clothing";
src/lib/demo-storage.ts:const OUTFITS_KEY = "stylescan_demo_outfits";
src/lib/demo-storage.ts:
src/lib/demo-storage.ts:let listeners: (() => void)[] = [];
src/lib/demo-storage.ts:
src/lib/demo-storage.ts:const notify = () => {
