src/components/OutfitGenerator.tsx:        name: suggestion.name,
src/components/OutfitGenerator.tsx:        itemIds,
src/components/OutfitGenerator.tsx:        date: format(selectedDate, "yyyy-MM-dd"),
src/components/OutfitGenerator.tsx:        photoUrl: "", // Virtual outfit
src/components/OutfitGenerator.tsx:        photoHash: "virtual",
src/components/OutfitGenerator.tsx:        hashtags: ["#suggestion", "#style"],
src/components/OutfitGenerator.tsx:        dominantColor: "Virtual",
src/components/OutfitGenerator.tsx:        occasion: occasion,
src/components/OutfitGenerator.tsx:        userId: user.uid,
