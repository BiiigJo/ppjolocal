src/components/WeatherWidget.tsx:export default function WeatherWidget({ onWeatherChange }: WeatherWidgetProps) {
src/components/WeatherWidget.tsx:  const [weather, setWeather] = useState<WeatherData | null>(null);
src/components/WeatherWidget.tsx:  const [loading, setLoading] = useState(true);
src/components/WeatherWidget.tsx:  const [error, setError] = useState<string | null>(null);
src/components/WeatherWidget.tsx:
src/components/WeatherWidget.tsx:  useEffect(() => {
src/components/WeatherWidget.tsx:    if (!navigator.geolocation) {
src/components/WeatherWidget.tsx:      setError("Géolocalisation non supportée");
src/components/WeatherWidget.tsx:      setLoading(false);
src/components/WeatherWidget.tsx:      return;
src/components/WeatherWidget.tsx:    }
src/components/WeatherWidget.tsx:
src/components/WeatherWidget.tsx:    navigator.geolocation.getCurrentPosition(
src/components/WeatherWidget.tsx:      async (position) => {
src/components/WeatherWidget.tsx:        try {
src/components/WeatherWidget.tsx:          const data = await fetchWeather(position.coords.latitude, position.coords.longitude);
src/components/WeatherWidget.tsx:          setWeather(data);
src/components/WeatherWidget.tsx:          onWeatherChange?.(data);
src/components/WeatherWidget.tsx:        } catch (err) {
src/components/WeatherWidget.tsx:          setError("Erreur météo");
src/components/WeatherWidget.tsx:        } finally {
src/components/WeatherWidget.tsx:          setLoading(false);
src/components/WeatherWidget.tsx:        }
src/components/WeatherWidget.tsx:      },
src/components/WeatherWidget.tsx:      (err) => {
src/components/WeatherWidget.tsx:        setError("Accès position refusé");
src/components/WeatherWidget.tsx:        setLoading(false);
src/components/WeatherWidget.tsx:      }
src/components/WeatherWidget.tsx:    );
src/components/WeatherWidget.tsx:  }, []);
src/components/WeatherWidget.tsx:
src/components/WeatherWidget.tsx:  if (loading) return null;
src/components/WeatherWidget.tsx:  if (error) return null;
src/components/WeatherWidget.tsx:  if (!weather) return null;
src/components/WeatherWidget.tsx:
src/components/WeatherWidget.tsx:  return (
src/components/WeatherWidget.tsx:    <Card className="p-4 rounded-2xl border-none shadow-sm bg-white/80 backdrop-blur-sm flex items-center justify-between">
src/components/WeatherWidget.tsx:      <div className="flex items-center gap-3">
src/components/WeatherWidget.tsx:        <div className="text-3xl">{weather.icon}</div>
src/components/WeatherWidget.tsx:        <div>
src/components/WeatherWidget.tsx:          <p className="text-sm font-bold text-zinc-900">{weather.temp}°C</p>
src/components/WeatherWidget.tsx:          <p className="text-[10px] text-zinc-500 font-medium uppercase tracking-wider">{weather.condition}</p>
src/components/WeatherWidget.tsx:        </div>
src/components/WeatherWidget.tsx:      </div>
src/components/WeatherWidget.tsx:      <div className="flex items-center gap-1 text-zinc-400">
src/components/WeatherWidget.tsx:        <MapPin className="w-3 h-3" />
src/components/WeatherWidget.tsx:        <span className="text-[10px] font-medium">{weather.city || "Ma Position"}</span>
src/components/WeatherWidget.tsx:      </div>
src/components/WeatherWidget.tsx:    </Card>
src/components/WeatherWidget.tsx:  );
src/components/WeatherWidget.tsx:}
